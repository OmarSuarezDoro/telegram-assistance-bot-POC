{
  "name": "telegram_bot_assistant_poc",
  "version": "1.0.0",
  "description": "A proof of concept for a Telegram bot assistant",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node dist/index.js",
    "build": "tsc",
    "dev": "concurrently \"tsc --watch\" \"nodemon dist/index.js\"",
