  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "child_process": "^1.0.2",
    "chrono-node": "^2.9.0",
    "dotenv": "^17.4.2",
    "node-telegram-bot-api": "^0.67.0",
    "pg": "^8.20.0"
  }
